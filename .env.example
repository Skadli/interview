# 复制为 .env 后填写。docker compose 会自动读取本文件。

# ============ 火山引擎凭证（生产必填）============
# 火山「语音技术 / 大模型流式语音识别」的 App Key 与 Access Key
VOLC_APP_KEY=
VOLC_ACCESS_KEY=
VOLC_RESOURCE_ID=volc.bigasr.sauc.duration
# 火山「方舟(豆包)」API Key
ARK_API_KEY=

# ============ Provider 选择 ============
# 还没有 key、只想先把界面和链路跑起来：把下面两个都改成 mock
ASR_PROVIDER=volc
LLM_PROVIDER=ark

# ============ 模型（最新豆包 1.6）============
MODEL_FAST=doubao-seed-1.6-flash     # 口语化：极速
MODEL_STRONG=doubao-seed-1.6          # 公考结构化：重质量

# ============ 可调参数 ============
SPEAKER_THRESH=0.75                   # 声纹判定阈值（越高越严）
ENDPOINT_MS=650                       # mock 模式断句静音窗（火山模式由服务端决定）
SESSION_TTL_SEC=1800
MAX_SESSIONS=500

# ============ 可选覆盖 ============
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# VOLC_ASR_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel
