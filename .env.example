# 复制为 .env 后填写。docker compose 会自动读取本文件。
# 本项目用到火山引擎【两个产品】，两个独立的 key：

# ① 火山「语音技术」大模型流式 ASR —— 新版控制台为单个 API Key（走 X-Api-Key）
VOLC_API_KEY=
# resource id 决定用哪个 ASR 模型（开通"豆包流式语音识别2.0·小时版"→ duration 即 2.0）
VOLC_RESOURCE_ID=volc.bigasr.sauc.duration
VOLC_ASR_MODEL=bigmodel
# 若仍是旧版控制台（App ID + Access Token 两段式），改用下面两项、并留空 VOLC_API_KEY：
# VOLC_APP_KEY=
# VOLC_ACCESS_KEY=

# ② 火山「方舟」豆包大模型（LLM + 简历结构化 + 公司简报）—— 在方舟控制台单独创建，
#    与上面的语音 key 不是同一个！
ARK_API_KEY=
# 上下文缓存(压低首字延迟)：需先在方舟建"推理接入点 ep-xxx"，把 MODEL_FAST/STRONG 设为 ep-id，再设 true
ARK_CONTEXT_CACHE=false

# （可选）想免 key 先把界面/链路跑起来：把 docker-compose 里 ASR_PROVIDER、LLM_PROVIDER 改成 mock。
