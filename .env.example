# 复制为 .env 后，只需填下面 3 个 key。其余配置已写死在 docker-compose 里。
# docker compose 会自动读取本文件。

# 火山「语音技术 / 大模型流式语音识别」的 App Key 与 Access Key
VOLC_APP_KEY=
VOLC_ACCESS_KEY=

# 火山「方舟(豆包)」API Key（LLM + 简历结构化 + 公司简报都用它）
ARK_API_KEY=

# （可选）想免 key 先把界面/链路跑起来：
#   把 docker-compose 里 backend 的 ASR_PROVIDER、LLM_PROVIDER 改成 mock 即可。
